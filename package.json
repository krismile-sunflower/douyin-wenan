{
  "name": "douyin-wenan",
  "version": "1.0.0",
  "description": "抖音视频链接解析、下载、文案提取服务（monorepo）",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev -w apps/api",
