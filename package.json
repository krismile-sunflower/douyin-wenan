    "lint": "eslint apps/ packages/",
    "test": "node apps/api/examples/test.js"
  },
  "keywords": [
    "douyin",
    "video",
    "transcription"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
